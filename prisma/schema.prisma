generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id            String         @id @default(uuid())
  nombre        String
  email         String         @unique
  password_hash String
  rol           RolUsuario
  municipio_id  String?
  municipio     Municipio?     @relation(fields: [municipio_id], references: [id])
  testigo_id    String?        @unique  // Vinculación con testigo (si rol = Testigo_Electoral)
  testigo       Testigo?       @relation(fields: [testigo_id], references: [id])
  alertas       AlertasMesa[]
  created_at    DateTime       @default(now())
}

enum RolUsuario {
  SuperAdmin
  Coordinador_Municipio
  Digitador
  Abogado_Juridico
  Testigo_Electoral
}

model Municipio {
  id               String              @id @default(uuid())
  codigo_municipio String              @unique
  nombre           String
  puestos          Divipole[]
  alertas          AlertasMesa[]
  usuarios         Usuario[]
  comisiones       ComisionEscrutadora[]
}

model Divipole {
  id             String         @id @default(uuid())
  municipio_id   String
  municipio      Municipio      @relation(fields: [municipio_id], references: [id])
  zona           String
  codigo_puesto  String
  nombre_puesto  String
  mesas          Int?
  testigos_asignados Testigo[]  @relation("PuestoAsignado")
  testigos_votantes  Testigo[]  @relation("PuestoVotacion")
  alertas        AlertasMesa[]
  actas_e14      ActaE14[]
  resultados     ResultadosMesa[]

  @@unique([municipio_id, zona, codigo_puesto])
}

model Testigo {
  id                 String        @id @default(uuid())
  cedula             String        @unique
  nombre             String
  telefono           String
  email              String?

  puesto_votacion_id String?
  puesto_votacion    Divipole?     @relation("PuestoVotacion", fields: [puesto_votacion_id], references: [id])
  mesa_votacion      Int?

  puesto_id          String
  puesto             Divipole      @relation("PuestoAsignado", fields: [puesto_id], references: [id])

  mesa               Int?
  tipo               TipoTestigo   @default(MESA)
  estado             EstadoTestigo @default(Disponible)
  usuario            Usuario?
  comision_titular   ComisionEscrutadora? @relation("ComisionTitular")
  comision_suplente  ComisionEscrutadora? @relation("ComisionSuplente")
  actas_e14          ActaE14[]
  created_at         DateTime      @default(now())
}

enum TipoTestigo {
  MESA
  COMISION_TITULAR
  COMISION_SUPLENTE
}

enum EstadoTestigo {
  Disponible
  Asignado
}

model ComisionEscrutadora {
  id            String    @id @default(uuid())
  municipio_id  String
  municipio     Municipio @relation(fields: [municipio_id], references: [id])
  nombre        String
  titular_id    String?   @unique
  titular       Testigo?  @relation("ComisionTitular", fields: [titular_id], references: [id])
  suplente_id   String?   @unique
  suplente      Testigo?  @relation("ComisionSuplente", fields: [suplente_id], references: [id])
  created_at    DateTime  @default(now())
}

model AlertasMesa {
  id            String       @id @default(uuid())
  tipo_alerta   String
  descripcion   String
  municipio_id  String
  municipio     Municipio    @relation(fields: [municipio_id], references: [id])
  puesto_id     String
  puesto        Divipole     @relation(fields: [puesto_id], references: [id])
  mesa          Int
  reportado_por String
  usuario       Usuario      @relation(fields: [reportado_por], references: [id])
  foto_url      String?
  estado        EstadoAlerta @default(Pendiente)
  created_at    DateTime     @default(now())
}

enum EstadoAlerta {
  Pendiente
  En_Revision
  Resuelta
}

model ActaE14 {
  id            String       @id @default(uuid())
  testigo_id    String
  testigo       Testigo      @relation(fields: [testigo_id], references: [id])
  puesto_id     String
  puesto        Divipole     @relation(fields: [puesto_id], references: [id])
  mesa          Int
  imagen_url    String
  ocr_data      Json?
  estado        EstadoE14    @default(Recibida)
  created_at    DateTime     @default(now())
}

enum EstadoE14 {
  Recibida
  Procesada_OCR
  Error_Lectura
}

model ResultadosMesa {
  id                    String          @id @default(uuid())
  puesto_id             String
  puesto                Divipole        @relation(fields: [puesto_id], references: [id])
  mesa                  Int
  fuente                FuenteResultado
  votos_cepeda          Int             @default(0)
  votos_clara           Int             @default(0)
  votos_claudia         Int             @default(0)
  votos_botero          Int             @default(0)
  votos_espriella       Int             @default(0)
  votos_lizcano         Int             @default(0)
  votos_miguel_uribe    Int             @default(0)
  votos_macollins       Int             @default(0)
  votos_roy             Int             @default(0)
  votos_caicedo         Int             @default(0)
  votos_matamoros       Int             @default(0)
  votos_paloma          Int             @default(0)
  votos_fajardo         Int             @default(0)
  votos_murillo         Int             @default(0)
  votos_blanco          Int             @default(0)
  votos_nulos           Int             @default(0)
  votos_no_marcados     Int             @default(0)
  votos_total           Int             @default(0)
  registrado_por        String?
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  @@unique([puesto_id, mesa, fuente])
}

enum FuenteResultado {
  TESTIGO
  PRECONTEO
  TRANSMISION
}
